{:paths ["src"]

 :deps {org.clojure/clojure {:mvn/version "1.12.0"}
        ;; Present from M0 so the dependency is settled; unused until M1.
        jepsen/jepsen       {:mvn/version "0.3.12"}}

 :aliases
 {;; The demo is example consumer code, not part of the library, so it is not
  ;; on :paths -- it comes in only for these aliases.
  :run  {:extra-paths ["examples"]
         :main-opts   ["-m" "demo.kvs"]}

  ;; Note the absence of "examples": the test suite stands on its own, on
  ;; fixtures in test/. The demo is documentation, not a dependency of it.
  :test {:extra-paths ["test"]
         :extra-deps  {io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts   ["-m" "cognitect.test-runner"]
         :exec-fn     cognitect.test-runner.api/test}}}
